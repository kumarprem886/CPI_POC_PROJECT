PORT=8081

# ── SAP CPI Tenant ────────────────────────────────────────────────────────────
CPI_BASE_URL=https://your-tenant.it-cpitrial05.cfapps.us10-001.hana.ondemand.com
CPI_USERNAME=your_email@company.com
CPI_PASSWORD=your_password_here

# ── Active AI Provider ────────────────────────────────────────────────────────
# Options: gemini | groq | openrouter | huggingface | mistral | nvidia | cohere | cloudflare | openai | anthropic | ollama
AI_PROVIDER=gemini

# ── FREE Providers ────────────────────────────────────────────────────────────

# 1. Google Gemini — FREE  (aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash-lite

# 2. Groq — FREE, ultra-fast LPU  (console.groq.com/keys)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# 3. OpenRouter — FREE models available  (openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# 4. Hugging Face — FREE inference API  (huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=hf_...
HUGGINGFACE_MODEL=meta-llama/Llama-3.2-3B-Instruct

# 5. Mistral AI — FREE tier  (console.mistral.ai/api-keys)
MISTRAL_API_KEY=...
MISTRAL_MODEL=open-mistral-nemo

# 6. NVIDIA NIM — FREE tier  (build.nvidia.com → Get API Key)
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# 7. Cohere — FREE tier  (dashboard.cohere.com/api-keys)
COHERE_API_KEY=...
COHERE_MODEL=command-r

# 8. Cloudflare Workers AI — FREE tier  (dash.cloudflare.com → API Tokens)
CLOUDFLARE_API_KEY=...
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# 9. Ollama — FREE, local, no key needed  (ollama.com — run: ollama serve)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── PAID Providers ────────────────────────────────────────────────────────────

# 10. OpenAI (platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# 11. Anthropic Claude (console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5174
